@model RoleVm

<div class="content-wrapper">
	<div class="page-header mb-4">
		<h3 class="page-title text-primary">⚙ Manage Role</h3>
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb">
				<li class="breadcrumb-item"><a asp-controller="Role" asp-action="Index" asp-area="Admin">Roles</a></li>
				<li class="breadcrumb-item active" aria-current="page">
					@(string.IsNullOrEmpty(Model.Id) ? "Create" : "Edit")
				</li>
			</ol>
		</nav>
	</div>

	<form method="post" asp-controller="Role" asp-area="Admin" asp-action="Save" role="form" class="row g-4 ">
		<div class="col-md-8">
			<div class="card shadow-sm border-0">
				<div class="card-body">
					<h4 class="card-title mb-3">Role Info</h4>
					<div asp-validation-summary="All" class="text-danger my-3"></div>

					<input asp-for="Id" type="hidden" />

					<div class="form-group mb-3">
						<label asp-for="Name" class="form-label fw-bold"></label>
						<input asp-for="Name" class="form-control" placeholder="Role Name" />
						<span asp-validation-for="Name" class="text-danger small"></span>
					</div>

					<div>
						<div  class="form-check form-switch d-flex align-items-center " style="width:75% ;margin:0 0 20px 40px">
							<input asp-for="IsDefault" class="form-check-input" type="checkbox" />
							<label asp-for="IsDefault" class="form-check-label fw-bold mb-0">
								Set as Default Role
							</label>
							<span asp-validation-for="IsDefault" class="text-danger small ms-2"></span>
						</div>
					</div>

					<div class="d-flex gap-2">
						<button type="submit" class="btn btn-gradient-primary px-4">💾 Save</button>
						<a asp-action="Index" asp-controller="Role" asp-area="Admin" class="btn btn-light px-4">↩ Back</a>
					</div>
				</div>
			</div>
		</div>


	</form>
</div>

@section Scripts {
	@await Html.PartialAsync("_ValidationScriptsPartial")
}
