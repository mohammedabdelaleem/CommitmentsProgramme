@model IEnumerable<ApplicationRole>

@{
    TempData[SharedData.MainTitle] = "Role Management";
}

<div class="container mt-4">
    <h2 class="mb-3">Roles List</h2>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover" id="roles-listing">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(x => x.Name)</th>
                    <th>@Html.DisplayNameFor(x => x.IsDefault)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody >
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="white-td " data-id="@item.Id">
                            <td><strong>@item.Name</strong></td>
                            <td>
                                @if (item.IsDefault)
                                {
                                    <span class="badge bg-success">Default</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    @if (!item.IsDefault)
                                    {
                                        <form asp-action="SetDefault" method="post">
                                            <input type="hidden" name="roleId" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                Set as Default
                                            </button>
                                        </form>
                                    }
                                    <a asp-controller="Role" asp-action="Edit" asp-area="Admin" asp-route-id="@item.Id"
                                       class="btn btn-warning text-white">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a onclick="deleteItem('@item.Id', 'Role')"
                                       class="btn btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                            <i class="bi bi-emoji-frown"></i> No roles found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm">
    @Html.AntiForgeryToken()
</form>

@{
    var addNewVm = new AreaControllerActionVm
            {
                Area = "Admin",
                Controller = "Role",
                Action = "Edit"
            };
}
<partial name="_Create" model="@addNewVm" />

@section Scripts {
    <script src="~/js/deleteitem.js"></script>
}
