@model RegisterVm

<section class="auth-page">

	<div class="container-fluid">

		<div class="row min-vh-100">

			<!-- LEFT -->

			<div class="col-lg-5 d-flex align-items-center justify-content-center bg-white">

				<div class="auth-form">

					<h2 class="fw-bold mb-2">

						إنشاء حساب جديد

					</h2>

					<p class="text-muted mb-4">

						لديك حساب بالفعل؟

						<a asp-action="Login">تسجيل الدخول</a>

					</p>

					<form asp-action="Register"
						  method="post">

						<div asp-validation-summary="All"
							 class="validation-summary"></div>

						<input hidden
							   name="returnUrl"
							   value="@ViewBag.ReturnUrl" />

						<div class="mb-3">

							<input asp-for="RegisterReq.FullName"
								   class="form-control form-control-lg"
								   placeholder="الاسم بالكامل" />

							<span asp-validation-for="RegisterReq.FullName"
								  class="text-danger small"></span>

						</div>

						<div class="mb-3">

							<input asp-for="RegisterReq.Email"
								   class="form-control form-control-lg"
								   autocomplete="email"
								   placeholder="البريد الإلكتروني" />

							<span asp-validation-for="RegisterReq.Email"
								  class="text-danger small"></span>

						</div>

						<div class="row">

							<div class="col-md-6 mb-3">

								<div class="position-relative">

									<input asp-for="RegisterReq.Password"
										   id="passwordInput"
										   type="password"
										   class="form-control form-control-lg pe-5"
										   autocomplete="new-password"
										   placeholder="كلمة المرور" />


									<i class="fa-solid fa-eye toggle-password-login"
									   onclick="togglePassword('passwordInput',this)"></i>

								</div>

								<span asp-validation-for="RegisterReq.Password"
									  class="text-danger small"></span>

							</div>

							<div class="col-md-6 mb-3">

								<div class="position-relative">

									<input asp-for="RegisterReq.ConfirmPassword"
										   id="confirmPasswordInput"
										   type="password"
										   class="form-control form-control-lg pe-5"
										   autocomplete="new-password"
										   placeholder="تاكيد " />

									<i class="fa-solid fa-eye toggle-password-login"
									   onclick="togglePassword('confirmPasswordInput',this)"></i>

								</div>

								<span asp-validation-for="RegisterReq.ConfirmPassword"
									  class="text-danger small"></span>

							</div>

						</div>

						<small id="passwordMatch" class="mb-3 d-block"></small>

						<div class="mb-3">

							<input asp-for="RegisterReq.Phone"
								   class="form-control form-control-lg"
								   autocomplete="tel"
								   placeholder="رقم المحمول" />

						</div>

						<div class="mb-3">

							<textarea asp-for="RegisterReq.Bio"
									  rows="3"
									  class="form-control"
									  autocomplete="off"
									  spellcheck="false"
									  placeholder="نبذة تعريفية (اختياري)"></textarea>

						</div>

						@if (User.IsInRole(DefaultRoles.Admin))

						{

							<div class="mb-3">

								<select asp-for="RegisterReq.Role"
										class="form-select">

									<option value="">اختر الدور الوظيفي</option>

									@foreach (var role in Model.Roles)

									{

										<option value="@role.Name">@role.Name</option>

									}

								</select>

							</div>

						}

						<button class="btn btn-primary btn-lg w-100">

							<i class="fa-solid fa-user-plus me-2"></i>

							تسجيل مستخدم جديد

						</button>

					</form>

				</div>

			</div>

			<!-- RIGHT -->

			<div class="col-lg-7 d-none d-lg-flex auth-right">

				<div class="text-center">

					<img src="@Url.Content("~/Uploads/Website/logo.png")"
						 class="auth-logo"
						 alt="شعار جهاز الخدمات العامة للقوات المسلحة" />

					<h2 class="fw-bold mt-4">
						منظومة إدارة الإلتزامات
					</h2>

					<p class="text-light opacity-75">
						Commitment Management System
					</p>

					<h5 class="text-white mt-2">
						جهاز الخدمات العامة للقوات المسلحة
					</h5>

				</div>

			</div>
			<hr class="auth-divider" />
		</div>

	</div>

</section>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />

	<script>
	

			// 🔥 Password
		const password = document.getElementById("passwordInput");
		const confirmPassword = document.getElementById("confirmPasswordInput");
		const matchText = document.getElementById("passwordMatch");

		function togglePassword(id, icon) {
			const input = document.getElementById(id);

			const isHidden = input.type === "password";
			input.type = isHidden ? "text" : "password";

			icon.classList.toggle("fa-eye");
			icon.classList.toggle("fa-eye-slash");

			icon.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
		}

		function checkPasswordMatch() {
			const pass = password.value.trim();
			const confirm = confirmPassword.value.trim();

			if (!confirm) {
				matchText.textContent = "";
				return;
			}

			if (pass === confirm) {
				matchText.textContent = "كلمتا المرور متطابقتان ✓";
				matchText.className = "text-success small";
			} else {
				matchText.textContent = "كلمتا المرور غير متطابقتين"
				matchText.className = "text-danger small";
			}
		}

		//  Handle typing + paste + autofill
		["input", "keyup", "change"].forEach(evt => {
			password.addEventListener(evt, checkPasswordMatch);
			confirmPassword.addEventListener(evt, checkPasswordMatch);
		});

		// Prevent form submit if mismatch
		document.querySelector("form").addEventListener("submit", function (e) {
			if (password.value !== confirmPassword.value) {
				e.preventDefault();
				matchText.textContent = "يجب تطابق كلمتي المرور قبل التسجيل";
				matchText.className = "text-danger small";

				confirmPassword.focus();
			}
		});

	</script>
}