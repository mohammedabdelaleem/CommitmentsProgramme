@model VerifyEmailVm

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml"; // adjust path to your layout
}

<!-- section start -->
<section class="pwd-page section-b-space">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 offset-lg-3">
                <div class="theme-card p-4">
                    <h2 class="mb-3 text-center">Forgot Your Password?</h2>
                    <p class="text-center mb-4">
                        Enter your email address below, and we’ll send you a link to reset your password.
                    </p>

                    <form asp-controller="Auth" asp-action="VerifyEmail" method="post" class="theme-form">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="form-group">
                            <input asp-for="Email" class="form-control" placeholder="Enter Your Email" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-group d-flex justify-content-between align-items-center mt-4">
                            <button type="submit" class="btn btn-outline-danger btn-solid">Send Reset Link</button>
                            <a asp-controller="Auth" asp-action="Login" class="fw-bold">Back to Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- section end -->
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
