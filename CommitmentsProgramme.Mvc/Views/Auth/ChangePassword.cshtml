@model ChangePasswordVm

<section class="auth-page">
    <div class="container-fluid">
        <div class="row min-vh-100">

            <!-- LEFT -->
            <div class="col-lg-5 d-flex align-items-center justify-content-center bg-white">

                <div class="auth-form">

                    <h2 class="fw-bold mb-2">
                        تغيير كلمة المرور
                    </h2>

                    <p class="text-muted mb-4">
                        قم بإدخال كلمة المرور الحالية ثم اختر كلمة مرور جديدة.
                    </p>

                    <form asp-action="ChangePassword" method="post">

                        <div asp-validation-summary="All"
                             class="validation-summary-errors text-danger"
                             style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")">
                        </div>

                        <!-- Current Password -->
                        <div class="mb-3">
                            <div class="position-relative">

                                <input asp-for="CurrentPassword"
                                       id="currentPassword"
                                       type="password"
                                       class="form-control form-control-lg pe-5"
                                       placeholder="كلمة المرور الحالية" />

                                <i class="fa-solid fa-eye toggle-password-login"
                                   onclick="togglePassword('currentPassword',this)"></i>

                            </div>

                            <span asp-validation-for="CurrentPassword"
                                  class="text-danger small"></span>
                        </div>

                        <!-- New Password -->
                        <div class="mb-3">
                            <div class="position-relative">

                                <input asp-for="NewPassword"
                                       id="newPassword"
                                       type="password"
                                       class="form-control form-control-lg pe-5"
                                       placeholder="كلمة المرور الجديدة" />

                                <i class="fa-solid fa-eye toggle-password-login"
                                   onclick="togglePassword('newPassword',this)"></i>

                            </div>

                            <span asp-validation-for="NewPassword"
                                  class="text-danger small"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-3">
                            <div class="position-relative">

                                <input asp-for="ConfirmedPassword"
                                       id="confirmPassword"
                                       type="password"
                                       class="form-control form-control-lg pe-5"
                                       placeholder="تأكيد كلمة المرور" />

                                <i class="fa-solid fa-eye toggle-password-login"
                                   onclick="togglePassword('confirmPassword',this)"></i>

                            </div>

                            <span asp-validation-for="ConfirmedPassword"
                                  class="text-danger small"></span>
                        </div>

                        <small id="passwordMatch" class="mb-3 d-block"></small>

                        <button class="btn btn-primary btn-lg w-100">
                            <i class="fa-solid fa-key me-2"></i>
                            تغيير كلمة المرور
                        </button>

                    </form>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-7 d-none d-lg-flex auth-right">

                <div class="text-center">

                    <img src="@Url.Content("~/Uploads/Website/logo.png")"
                         class="auth-logo"
                         alt="شعار جهاز الخدمات العامة للقوات المسلحة" />

                    <h2 class="fw-bold mt-4">
                        منظومة إدارة الإلتزامات
                    </h2>

                    <p class="text-light opacity-75">
                        Commitment Management System
                    </p>

                    <h5 class="text-white mt-2">
                        جهاز الخدمات العامة للقوات المسلحة
                    </h5>

                </div>

            </div>

        </div>
    </div>
</section>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>

        const newPassword = document.getElementById("newPassword");
        const confirmPassword = document.getElementById("confirmPassword");
        const matchText = document.getElementById("passwordMatch");

        function togglePassword(id, icon) {

            const input = document.getElementById(id);

            const hidden = input.type === "password";

            input.type = hidden ? "text" : "password";

            icon.classList.toggle("fa-eye");
            icon.classList.toggle("fa-eye-slash");
        }

        function checkPasswordMatch() {

            if (!confirmPassword.value) {
                matchText.textContent = "";
                return;
            }

            if (newPassword.value === confirmPassword.value) {

                matchText.textContent = "كلمتا المرور متطابقتان ✓";
                matchText.className = "text-success small";

            } else {

                matchText.textContent = "كلمتا المرور غير متطابقتين";
                matchText.className = "text-danger small";
            }
        }

        ["input","keyup","change"].forEach(e => {

            newPassword.addEventListener(e, checkPasswordMatch);
            confirmPassword.addEventListener(e, checkPasswordMatch);

        });

    </script>
}