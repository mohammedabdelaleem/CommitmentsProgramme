@{
    ViewData["Title"] = "Password Reset Email Sent";
    Layout = "~/Views/Shared/_Layout.cshtml"; // adjust if your layout path differs
}

<!-- section start -->
<section class="pwd-page section-b-space">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 offset-lg-3 text-center">
                <div class="theme-card p-4">
                    <h2 class="mb-3">Check Your Email</h2>
                    <p class="mt-2">
                        If an account with the provided email exists, a password reset link has been sent.
                        Please check your inbox (and spam/junk folder).
                    </p>

                    <div class="mt-4">
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-solid">
                            Back to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- section end -->
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
