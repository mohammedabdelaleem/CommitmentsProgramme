@model DailyPlanDetailsVm

@{
    ViewData["Title"] = "تفاصيل الخطة اليومية";
}

@if (Model.Id == 0)
{
    <div class="alert alert-warning text-center position-relative">
        لا توجد خطة يومية لهذا التاريخ.

        <div class=" d-flex justify-content-center align-items-center float-end ">
            <a class="btn btn-primary" asp-action="Create" style="position:absolute;left:78px;top: 10px; ">
                + إنشاء خطة جديدة
            </a>
        </div>
    </div>

    
    return;
}

<div class="container mt-3">

    <div class="row mb-4">
        <div class="col-12">

            <div class="card shadow-sm">

                <div class="card-header bg-primary text-white">

                    <h3 class="mb-0">
                        الخطة اليومية
                    </h3>

                </div>

                <div class="card-body">

                    <h5>
                        التاريخ :
                        @Model.PlanDate.ToString("dd/MM/yyyy")
                    </h5>

                </div>

            </div>

        </div>
    </div>


 
    <div class="card shadow-sm">

        <div class="card-header bg-secondary text-white">

            <h4 class="mb-0">
                الالتزامات الداخلية
            </h4>

        </div>

        <div class="card-body p-0">

            <table class="table table-bordered table-striped mb-0">

                <thead class="table-light">

                    <tr>

                        <th style="width:90px">الوقت</th>

                        <th>الالتزام</th>

                        <th>المكان</th>

                        <th style="width:220px">الأفرع</th>

                        <th style="width:220px">الحضور</th>

                        <th>الملاحظات</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.InsideCommitments.Any())
                    {
                        @foreach (var item in Model.InsideCommitments)
                        {
                            <tr>

                                <td>@item.Time</td>

                                <td>@item.Title</td>

                                <td>@item.PlaceName</td>

                                <td>

                                    <ul class="mb-0">

                                        @foreach (var branch in item.BranchNames)
                                        {
                                            <li>@branch</li>
                                        }

                                    </ul>

                                </td>

                                <td>

                                    <ul class="mb-0">

                                        @foreach (var attendance in item.AttendanceNames)
                                        {
                                            <li>@attendance</li>
                                        }

                                    </ul>

                                </td>

                                <td>@item.Notes</td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="6" class="text-center text-muted">

                                لا توجد التزامات داخلية

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div class="card shadow-sm mt-5">

        <div class="card-header bg-dark text-white">

            <h4 class="mb-0">
                الالتزامات الخارجية
            </h4>

        </div>

        <div class="card-body p-0">

            <table class="table table-bordered table-striped mb-0">

                <thead class="table-light">

                    <tr>

                        <th style="width:90px">الوقت</th>

                        <th>الالتزام</th>

                        <th>المكان</th>

                        <th style="width:220px">الأفرع</th>

                        <th style="width:220px">الحضور</th>

                        <th>الملاحظات</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.OutsideCommitments.Any())
                    {
                        @foreach (var item in Model.OutsideCommitments)
                        {
                            <tr>

                                <td>@item.Time</td>

                                <td>@item.Title</td>

                                <td>@item.PlaceName</td>

                                <td>

                                    <ul class="mb-0">

                                        @foreach (var branch in item.BranchNames)
                                        {
                                            <li>@branch</li>
                                        }

                                    </ul>

                                </td>

                                <td>

                                    <ul class="mb-0">

                                        @foreach (var attendance in item.AttendanceNames)
                                        {
                                            <li>@attendance</li>
                                        }

                                    </ul>

                                </td>

                                <td>@item.Notes</td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="6" class="text-center text-muted">

                                لا توجد التزامات خارجية

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>





    <div class="row mb-4">

        <div class="col-md-6">

            <div class="card border-primary shadow-sm h-100">

                <div class="card-header bg-primary text-white text-center">
                    ضابط عظيم
                </div>

                <div class="card-body">

                    <table class="table table-bordered mb-0">

                        <tr>
                            <th style="width:35%">الرتبة / الاسم</th>
                            <td>
                                @Model.SeniorOfficer.RankName
                                /
                                @Model.SeniorOfficer.FullName
                            </td>
                        </tr>

                        <tr>
                            <th>رقم الهاتف</th>
                            <td>@Model.SeniorOfficer.PhoneNumber</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>


        <div class="col-md-6">

            <div class="card border-success shadow-sm h-100">

                <div class="card-header bg-success text-white text-center">
                    ضابط النوبتجية
                </div>

                <div class="card-body">

                    <table class="table table-bordered mb-0">

                        <tr>
                            <th style="width:35%">الرتبة / الاسم</th>
                            <td>
                                @Model.DutyOfficer.RankName
                                /
                                @Model.DutyOfficer.FullName
                            </td>
                        </tr>

                        <tr>
                            <th>رقم الهاتف</th>
                            <td>@Model.DutyOfficer.PhoneNumber</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>


    <div class="d-flex gap-3 mt-4">

        <a asp-action="Index"
           class="btn btn-light shadow-sm rounded-circle"
           title="رجوع">
            <i class="fa-solid fa-arrow-left"></i>
        </a>

        <a asp-action="Create"
           asp-route-id="@Model.Id"
           class="btn btn-primary shadow-sm rounded-circle"
           title="تعديل">
            <i class="fa-solid fa-pen-to-square"></i>
        </a>

        <a asp-action="Print"
           asp-route-id="@Model.Id"
           class="btn btn-success shadow-sm rounded-circle"
           title="طباعة">
            <i class="fa-solid fa-print"></i>
        </a>

        <a asp-action="Delete"
           asp-route-id="@Model.Id"
           class="btn btn-danger shadow-sm rounded-circle"
           title="حذف"
           onclick="return confirm('هل أنت متأكد من الحذف؟');">
            <i class="fa-solid fa-trash-can"></i>
        </a>

    </div>

</div>