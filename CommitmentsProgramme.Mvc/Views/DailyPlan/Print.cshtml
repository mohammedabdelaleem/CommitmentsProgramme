@model DailyPlanPrintVm

@{
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl">
<head>
    <meta charset="utf-8" />

    <style>

            body {
                font-family: Tahoma;
                direction: rtl;
                margin: 20px;
            }

            .report {
                width: 100%;
                border-collapse: collapse;
                border: 4px solid #000;
            }

                .report td {
                    border: 2px solid #000;
                }

            .header-table,
            .officers-table,
            .commitments-table {
                width: 100%;
                border-collapse: collapse;
            }

                .header-table td,
                .officers-table td,
                .commitments-table td,
                .commitments-table th {
                    border: 1px solid #000;
                    padding: 8px;
                }

            .header {
                text-align: center;
                font-size: 22px;
                font-weight: bold;
            }

            .logo {
                width: 120px;
                text-align: center;
            }

            .date-row {
                padding: 10px;
                font-weight: bold;
            }

            .section-title {
                text-align: center;
                font-weight: bold;
                font-size: 18px;
                padding: 8px;
                background: #f3f3f3;
            }

            .commitments-table th {
                text-align: center;
            }

            .commitments-table td {
                vertical-align: top;
            }

            ul {
                margin: 0;
                padding-right: 18px;
            }

            .signature {
                height: 120px;
            }

    </style>
</head>

<body>

    <table class="report">

        <!-- HEADER -->

        <tr>
            <td>

                <table class="header-table">

                    <tr>

                        <td class="logo">
                            <img src="~/Uploads/Website/logo.png"/>
                        </td>

                        <td class="header">

                            الخطة اليومية

                            <br />

                            إدارة .........

                        </td>

                    </tr>

                </table>

            </td>
        </tr>

        <!-- DATE -->

        <tr>
            <td class="date-row">

                التاريخ :
                @Model.PlanDate.ToString("dd/MM/yyyy")

            </td>
        </tr>

        <!-- INSIDE -->

        <tr>
            <td>

                <div class="section-title">
                    الالتزامات الداخلية
                </div>

                <table class="commitments-table">

                    <thead>

                        <tr>

                            <th>م</th>
                            <th>الوقت</th>
                            <th>الالتزام</th>
                            <th>المكان</th>
                            <th>القطاعات</th>
                            <th>الحضور</th>

                        </tr>

                    </thead>

                    <tbody>

                        @{
                            int insideIndex = 1;
                        }

                        @foreach (var item in Model.InsideCommitments)
                        {
                            <tr>

                                <td>@insideIndex</td>

                                <td>@item.Time.ToString("HH:mm")</td>

                                <td>@item.Title</td>

                                <td>@item.PlaceName</td>

                                <td>

                                    <ul>

                                        @foreach (var branch in item.Branches)
                                        {
                                            <li>@branch</li>
                                        }

                                    </ul>

                                </td>

                                <td>

                                    <ul>

                                        @foreach (var attendance in item.Attendances)
                                        {
                                            <li>@attendance</li>
                                        }

                                    </ul>

                                </td>

                            </tr>

                            insideIndex++;
                        }

                    </tbody>

                </table>

            </td>
        </tr>

        <!-- OUTSIDE -->

        <tr>
            <td>

                <div class="section-title">
                    الالتزامات الخارجية
                </div>

                <table class="commitments-table">

                    <thead>

                        <tr>

                            <th>م</th>
                            <th>الوقت</th>
                            <th>الالتزام</th>
                            <th>المكان</th>
                            <th>القطاعات</th>
                            <th>الحضور</th>

                        </tr>

                    </thead>

                    <tbody>

                        @{
                            int index = 1;
                        }

                        @foreach (var item in Model.OutsideCommitments)
                        {
                            <tr>

                                <td>@index</td>

                                <td>@item.Time.ToString("HH:mm")</td>

                                <td>@item.Title</td>

                                <td>@item.PlaceName</td>

                                <td>

                                    <ul>

                                        @foreach (var branch in item.Branches)
                                        {
                                            <li>@branch</li>
                                        }

                                    </ul>

                                </td>

                                <td>

                                    <ul>

                                        @foreach (var attendance in item.Attendances)
                                        {
                                            <li>@attendance</li>
                                        }

                                    </ul>

                                </td>

                            </tr>

                            index++;
                        }

                    </tbody>

                </table>

            </td>
        </tr>

      

        <!-- OFFICERS -->

        <tr>

            <td>

                <table class="officers-table">

                    <tr>

                        <td width="50%">

                            <b>ضابط عظيم</b>

                            <hr />

                            @Model.SeniorOfficerRank
                            /
                            @Model.SeniorOfficerName

                            <br />

                            @Model.SeniorOfficerPhone

                        </td>

                        <td width="50%">

                            <b>ضابط النوبتجية</b>

                            <hr />

                            @Model.DutyOfficerRank
                            /
                            @Model.DutyOfficerName

                            <br />

                            @Model.DutyOfficerPhone

                        </td>

                    </tr>

                </table>

            </td>

        </tr>


        <!-- FOOTER -->

        <tr>

            <td class="signature">

                <table style="width:100%;border-collapse:collapse">

                    <tr>

                        <td style="width:50%;border:none">
                            التوقيع
                        </td>

                        <td style="width:50%;border:none;text-align:left">
                            يعتمد
                        </td>

                    </tr>

                </table>

            </td>

        </tr>

    </table>

</body>
</html>