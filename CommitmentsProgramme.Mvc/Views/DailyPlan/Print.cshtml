@using System.Globalization
@model DailyPlanPrintVm

@{
    Layout = null;

    string ArabicTime(TimeOnly? time)
    {
        if (time == null)
            return "";

        var dt = DateTime.Today.Add(time.Value.ToTimeSpan());

        int hour = dt.Hour % 12;

        if (hour == 0)
            hour = 12;

        string period = dt.Hour >= 12 ? "م" : "ص";

        return $"{hour:00}:{dt:mm}{period}";
    }
}

<!doctype html>

<html lang="ar" dir="rtl">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>الإلتزامات الرئيسية</title>

    <link rel="stylesheet"
          href="@Url.Content("~/css/print-report.css")" />

</head>

<body>

    <main class="page">
        <div class="page-content">
            <header class="top">

                <div class="agency">
                    جهاز الخدمات العامة للقوات المسلحة
                </div>

                <img class="logo"
                     src="@Url.Content("~/Uploads/Website/logo.png")" />

                <div class="text-center middle-main-title">

                    <p class="main-title">

                        الإلتزامات الرئيسية عن يوم

                        @Model.PlanDate.ToString("dddd", new CultureInfo("ar-EG")).ToArabic()

                        الموافق

                        @Model.PlanDate.ToString("yyyy/MM/dd", new CultureInfo("ar-EG")).ToArabic()

                    </p>

                </div>

            </header>

            <div class="section-title">

                الإلتزامات الداخلية

            </div>


            @{
                int insideIndex = 1;
            }

            @if (Model?.InsideCommitments.Any() == true)
            {
                <table class="report-table">

                    <colgroup>
                        <col class="col-number">
                        <col class="col-time">
                        <col class="col-title">
                        <col class="col-attendance">
                        <col class="col-place">
                        <col class="col-branch">
                    </colgroup>

                    <thead>
                        <tr>
                            <th>م</th>
                            <th>الساعة</th>
                            <th>الإلتزام</th>
                            <th>الحاضرون</th>
                            <th>المكان</th>
                            <th>الفرع المختص</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.InsideCommitments)
                        {
                            <tr>

                                <td>@insideIndex.ToString().ToArabic()</td>

                                <td>@ArabicTime(item?.Time).ToArabic()</td>

                                <td class="text-cell">
                                    @item?.Title
                                </td>

                                <td class="text-cell">

                                    @if (item?.Attendances.Any() == true)
                                    {
                                        <ul class="report-list">
                                            @foreach (var attendance in item.Attendances)
                                            {
                                                <li>@attendance</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span>لا يوجد</span>
                                    }

                                </td>

                                <td>
                                    @item?.PlaceName
                                </td>

                                <td class="text-cell">

                                    @if (item?.Branches.Any() == true)
                                    {
                                        <ul class="report-list">
                                            @foreach (var branch in item.Branches)
                                            {
                                                <li>@branch</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span>لا يوجد</span>
                                    }

                                </td>

                            </tr>

                            insideIndex++;
                        }

                    </tbody>

                </table>
            }
            else
            {
                <table class="report-table">
                    <tbody>
                        <tr>
                            <td colspan="6" class="empty-message">
                                لا توجد التزامات داخلية
                            </td>
                        </tr>
                    </tbody>

                </table>
            }

            <div class="section-title">
                الإلتزامات الخارجية
            </div>

           

            @{
                int outsideIndex = 1;
            }

            @if (Model?.OutsideCommitments.Any() == true)
            {
                <table class="report-table">

                    <colgroup>
                        <col class="col-number">
                        <col class="col-time">
                        <col class="col-title">
                        <col class="col-attendance">
                        <col class="col-place">
                        <col class="col-branch">
                    </colgroup>

                    <thead>
                        <tr>
                            <th>م</th>
                            <th>الساعة</th>
                            <th>الإلتزام</th>
                            <th>الحاضرون</th>
                            <th>المكان</th>
                            <th>الفرع المختص</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.OutsideCommitments)
                        {
                            <tr>

                                <td>@outsideIndex.ToString().ToArabic()</td>

                                <td>@ArabicTime(item?.Time).ToArabic()</td>

                                <td class="text-cell">
                                    @item?.Title
                                </td>

                                <td class="text-cell">

                                    @if (item?.Attendances.Any() == true)
                                    {
                                        <ul class="report-list">
                                            @foreach (var attendance in item.Attendances)
                                            {
                                                <li>@attendance</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span>لا يوجد</span>
                                    }

                                </td>

                                <td>
                                    @item?.PlaceName
                                </td>

                                <td class="text-cell">

                                    @if (item?.Branches.Any()==true)
                                    {
                                        <ul class="report-list">
                                            @foreach (var branch in item.Branches)
                                            {
                                                <li>@branch</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span>لا يوجد</span>
                                    }

                                </td>

                            </tr>

                            outsideIndex++;
                        }

                    </tbody>

                </table>
            }
            else
            {
                <table class="report-table">
                    <tbody>
                        <tr>
                            <td colspan="6" class="empty-message">
                                لا توجد التزامات خارجية
                            </td>
                        </tr>
                    </tbody>

                </table>
            }

              
            <table class="signatures">

                <tbody>

                    <tr>

                        <td>ضابط عظيم</td>

                        <td>ضابط نوبتجي الإدارة العامة</td>

                    </tr>

                    <tr>

                        <td>

                            @Model?.SeniorOfficerRank

                            /

                            @Model?.SeniorOfficerName

                        </td>

                        <td>

                            @Model?.DutyOfficerRank

                            /

                            @Model?.DutyOfficerName

                        </td>

                    </tr>

                    <tr>

                        <td>@Model?.SeniorOfficerPhone?.ToArabic()</td>

                        <td>@Model?.DutyOfficerPhone?.ToArabic()</td>

                    </tr>

                </tbody>

            </table>
        </div>
    </main>


    <script> document.body.innerHTML = document.body.innerHTML.replace(/\d/g, d => '٠١٢٣٤٥٦٧٨٩'[d] ); </script>
</body>

</html>