@model DailyPlanPrintVm

@{
    Layout = null;
}

<!DOCTYPE html>

<html dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>الخطة اليومية</title>

    <style>

            body {
                font-family: Tahoma;
                margin: 20px;
                direction: rtl;
            }

            .header {
                text-align: center;
                margin-bottom: 20px;
            }

            .officers {
                display: flex;
                justify-content: space-between;
                gap: 20px;
                margin-bottom: 20px;
            }

            .officer-card {
                width: 48%;
                border: 1px solid #000;
                padding: 10px;
            }

                .officer-card h4 {
                    text-align: center;
                    margin-bottom: 15px;
                }

            .officer-row {
                margin-bottom: 10px;
            }

            table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 25px;
            }

            table, th, td {
                border: 1px solid black;
            }

            th {
                background-color: #eee;
            }

            th, td {
                padding: 8px;
                vertical-align: top;
            }

            ul {
                margin: 0;
                padding-right: 18px;
            }

    </style>
</head>

<body>

    <div class="header">
        <h2>الخطة اليومية</h2>
        <h4>@Model.PlanDate.ToString("dd/MM/yyyy")</h4>
    </div>

    <div class="officers">

        <div class="officer-card">
            <h4>ضابط عظيم</h4>

            <div class="officer-row">
                <strong>الرتبة / الاسم:</strong>
                @Model.SeniorOfficerRank @Model.SeniorOfficerName
            </div>

            <div class="officer-row">
                <strong>الهاتف:</strong>
                @Model.SeniorOfficerPhone
            </div>
        </div>

        <div class="officer-card">
            <h4>ضابط النوبتجية</h4>

            <div class="officer-row">
                <strong>الرتبة / الاسم:</strong>
                @Model.DutyOfficerRank @Model.DutyOfficerName
            </div>

            <div class="officer-row">
                <strong>الهاتف:</strong>
                @Model.DutyOfficerPhone
            </div>
        </div>

    </div>

    <h3>الالتزامات الخارجية</h3>

    <table>
        <thead>
            <tr>
                <th>الوقت</th>
                <th>العنوان</th>
                <th>المكان</th>
                <th>الأفرع</th>
                <th>الحضور</th>
                <th>ملاحظات</th>
            </tr>
        </thead>
        <tbody>

            @foreach (var item in Model.OutsideCommitments)
            {
                <tr>

                    <td>@item.Time</td>

                    <td>@item.Title</td>

                    <td>@item.PlaceName</td>

                    <td>
                        <ul>
                            @foreach (var branch in item.Branches)
                            {
                                <li>@branch</li>
                            }
                        </ul>
                    </td>

                    <td>
                        <ul>
                            @foreach (var attendance in item.Attendances)
                            {
                                <li>@attendance</li>
                            }
                        </ul>
                    </td>

                    <td>@item.Notes</td>

                </tr>
            }

        </tbody>
    </table>

    <h3>الالتزامات الداخلية</h3>

    <table>
        <thead>
            <tr>
                <th>الوقت</th>
                <th>العنوان</th>
                <th>المكان</th>
                <th>الأفرع</th>
                <th>الحضور</th>
                <th>ملاحظات</th>
            </tr>
        </thead>
        <tbody>

            @foreach (var item in Model.InsideCommitments)
            {
                <tr>

                    <td>@item.Time</td>

                    <td>@item.Title</td>

                    <td>@item.PlaceName</td>

                    <td>
                        <ul>
                            @foreach (var branch in item.Branches)
                            {
                                <li>@branch</li>
                            }
                        </ul>
                    </td>

                    <td>
                        <ul>
                            @foreach (var attendance in item.Attendances)
                            {
                                <li>@attendance</li>
                            }
                        </ul>
                    </td>

                    <td>@item.Notes</td>

                </tr>
            }

        </tbody>
    </table>

</body>
</html>