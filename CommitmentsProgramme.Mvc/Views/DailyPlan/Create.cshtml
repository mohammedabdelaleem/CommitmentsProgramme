@model DailyPlanVm

@{
    ViewData["Title"] = "إنشاء خطة يومية";
    var index = Model.Commitments?.Count ?? 0;
}

<div class="container py-4">

    <h3 class="mb-4">إنشاء خطة يومية</h3>

    <form asp-action="Create" method="post">

        <!-- ================= HEADER ================= -->

        <div class="row mb-3">

            <div class="col-md-4">
                <label>التاريخ</label>
                <input asp-for="PlanDate" type="date" class="form-control" />
            </div>

            <div class="col-md-4">
                <label>ظابط عظيم</label>
                <select asp-for="SeniorOfficerId"
                        asp-items="Model.SeniorOfficers"
                        class="form-control"></select>
            </div>

            <div class="col-md-4">
                <label>ظابط نوبتجي</label>
                <select asp-for="DutyOfficerId"
                        asp-items="Model.DutyOfficers"
                        class="form-control"></select>
            </div>

        </div>

        <hr />

        <h5>الالتزامات</h5>

        <!-- ================= COMMITMENTS ================= -->

        <div id="commitmentsContainer">

            @for (int i = 0; i < Model.Commitments.Count; i++)
            {
                <div class="card p-3 mb-3 commitment-row">

                    <input type="hidden" name="Commitments.Index" value="@i" />

                    <div class="row">

                        <div class="col-md-4">
                            <label>العنوان</label>
                            <input name="Commitments[@i].Title"
                                   value="@Model.Commitments[i].Title"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label>الوقت</label>
                            <input type="time"
                                   name="Commitments[@i].Time"
                                   value="@Model.Commitments[i].Time"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label>النوع</label>
                            <select name="Commitments[@i].CommitmentTypeId"
                                    asp-items="Model.CommitmentTypes"
                                    class="form-control"></select>
                        </div>

                        <div class="col-md-4 mt-2">
                            <label>الأولوية</label>
                            <select name="Commitments[@i].PriorityId"
                                    asp-items="Model.Priorities"
                                    class="form-control"></select>
                        </div>

                        <div class="col-md-4 mt-2">
                            <label>المكان</label>
                            <select name="Commitments[@i].PlaceId"
                                    asp-items="Model.Places"
                                    class="form-control"></select>
                        </div>

                        <!-- Branches -->
                        <div class="col-md-4 mt-2">
                            <label>الفروع</label>
                            <select multiple
                                    name="Commitments[@i].BranchIds"
                                    class="form-control">
                                @foreach (var b in Model.Branches)
                                {
                                    <option value="@b.Value">
                                        @b.Text
                                    </option>
                                }
                            </select>
                        </div>

                        <!-- Attendances -->
                        <div class="col-md-6 mt-2">
                            <label>الحضور</label>
                            <select multiple
                                    name="Commitments[@i].AttendanceIds"
                                    class="form-control">
                                @foreach (var a in Model.Attendances)
                                {
                                    <option value="@a.Value">
                                        @a.Text
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6 mt-2">
                            <label>ملاحظات</label>
                            <textarea name="Commitments[@i].Notes"
                                      class="form-control">@Model.Commitments[i].Notes</textarea>
                        </div>

                    </div>
                </div>
            }

        </div>

        <button type="button"
                id="btnAddCommitment"
                class="btn btn-success mt-3">
            + إضافة التزام
        </button>

        <hr />

        <button type="submit" class="btn btn-primary">
            حفظ
        </button>

    </form>

</div>

@section Scripts {

    <script>

        let index = @index;

        // ================= ADD NEW COMMITMENT =================
        $("#btnAddCommitment").on("click", function () {

            let branchesOptions = `@Html.Raw(string.Join("", Model.Branches.Select(b => $"<option value='{b.Value}'>{b.Text}</option>")))`;
            let attendanceOptions = `@Html.Raw(string.Join("", Model.Attendances.Select(a => $"<option value='{a.Value}'>{a.Text}</option>")))`;

            let commitmentTypes = `@Html.Raw(string.Join("", Model.CommitmentTypes.Select(x => $"<option value='{x.Value}'>{x.Text}</option>")))`;
            let priorities = `@Html.Raw(string.Join("", Model.Priorities.Select(x => $"<option value='{x.Value}'>{x.Text}</option>")))`;
            let places = `@Html.Raw(string.Join("", Model.Places.Select(x => $"<option value='{x.Value}'>{x.Text}</option>")))`;

            let html = `
            <div class="card p-3 mb-3 commitment-row">

                <input type="hidden" name="Commitments.Index" value="${index}" />

                <div class="row">

                    <div class="col-md-4">
                        <label>العنوان</label>
                        <input name="Commitments[${index}].Title" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label>الوقت</label>
                        <input type="time" name="Commitments[${index}].Time" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label>النوع</label>
                        <select name="Commitments[${index}].CommitmentTypeId" class="form-control">
                            ${commitmentTypes}
                        </select>
                    </div>

                    <div class="col-md-4 mt-2">
                        <label>الأولوية</label>
                        <select name="Commitments[${index}].PriorityId" class="form-control">
                            ${priorities}
                        </select>
                    </div>

                    <div class="col-md-4 mt-2">
                        <label>المكان</label>
                        <select name="Commitments[${index}].PlaceId" class="form-control">
                            ${places}
                        </select>
                    </div>

                    <div class="col-md-4 mt-2">
                        <label>الفروع</label>
                        <select multiple name="Commitments[${index}].BranchIds" class="form-control">
                            ${branchesOptions}
                        </select>
                    </div>

                    <div class="col-md-6 mt-2">
                        <label>الحضور</label>
                        <select multiple name="Commitments[${index}].AttendanceIds" class="form-control">
                            ${attendanceOptions}
                        </select>
                    </div>

                    <div class="col-md-6 mt-2">
                        <label>ملاحظات</label>
                        <textarea name="Commitments[${index}].Notes" class="form-control"></textarea>
                    </div>

                </div>

            </div>
            `;

            $("#commitmentsContainer").append(html);

            index++;
        });

    </script>

}