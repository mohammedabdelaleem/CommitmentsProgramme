@using System.Text.Json

<script>

let commitments = [];
let editIndex = -1;
let modal;

$(document).ready(function () {

// =====================
// BOOTSTRAP MODAL
// =====================
modal = new bootstrap.Modal(
document.getElementById("commitmentModal")
);

// =====================
// SELECT2 INIT (ONCE)
// =====================
$(".select2").select2({
width: "100%",
dir: "rtl",
dropdownParent: $("#commitmentModal"),
placeholder: "",
allowClear: true
});

$(".select2-multiple").select2({
width: "100%",
dir: "rtl",
dropdownParent: $("#commitmentModal"),
placeholder: "",
closeOnSelect: false
});

// =====================
// LOAD EDIT DATA
// =====================
        @if (Model.Commitments != null && Model.Commitments.Count > 0)
{
    <text>
        commitments = @Html.Raw(
                        JsonSerializer.Serialize(
                                Model.Commitments,
                                new JsonSerializerOptions
                                {
                                    PropertyNamingPolicy = JsonNamingPolicy.CamelCase
                                }
                        )
                                                );

        console.log("Loaded Commitments:", commitments);

        renderTable();
    </text>
}

// =====================
// OPEN MODAL
// =====================
$("#btnAddCommitment").on("click", function () {

clearModal();

editIndex = -1;

modal.show();
});

// =====================
// SAVE COMMITMENT
// =====================
$("#btnSaveCommitment").on("click", function () {

if (!$("#cTitle").val()) {

toastr.error("من فضلك أدخل عنوان الالتزام");

return;
}

const commitment = {

id: 0,

title: $("#cTitle").val(),

time: $("#cTime").val(),

commitmentTypeId: $("#cType").val(),

priorityId: $("#cPriority").val(),

placeId: $("#cPlace").val(),

branchIds: $("#cBranches").val() || [],

attendanceIds: $("#cAttendances").val() || [],

notes: $("#cNotes").val(),

commitmentTypeName:
$("#cType option:selected").text(),

placeName:
$("#cPlace option:selected").text()
};

if (editIndex >= 0)
commitments[editIndex] = commitment;
else
commitments.push(commitment);

renderTable();

modal.hide();
});

// =====================
// DELETE
// =====================
$(document).on("click", ".delete-btn", function () {

const index = $(this).data("index");

commitments.splice(index, 1);

renderTable();
});

// =====================
// EDIT
// =====================
$(document).on("click", ".edit-btn", function () {

editIndex = $(this).data("index");

const c = commitments[editIndex];

console.log("Editing:", c);

$("#cTitle").val(c.title);

$("#cTime").val(c.time);

$("#cType")
.val(c.commitmentTypeId?.toString())
.trigger("change");

$("#cPriority")
.val(c.priorityId?.toString())
.trigger("change");

$("#cPlace")
.val(c.placeId?.toString())
.trigger("change");

$("#cBranches")
.val(
(c.branchIds || [])
.map(x => x.toString())
)
.trigger("change");

$("#cAttendances")
.val(
(c.attendanceIds || [])
.map(x => x.toString())
)
.trigger("change");

$("#cNotes").val(c.notes);

modal.show();
});

// =====================
// SUBMIT
// =====================
$("#dailyPlanForm").on("submit", function () {

generateHiddenInputs();

return true;
});

});

// =====================
// RENDER TABLE
// =====================
function renderTable() {

const tbody = $("#commitmentsTableBody");

tbody.empty();

if (!commitments.length) {

tbody.append(`
<tr>
    <td colspan="5"
        class="text-center text-muted">
        لا توجد التزامات
    </td>
</tr>
`);

generateHiddenInputs();

return;
}

commitments.forEach((c, index) => {

tbody.append(`
<tr>

    <td>${c.time ?? ""}</td>

    <td>${c.title ?? ""}</td>

    <td>${c.commitmentTypeName ?? ""}</td>

    <td>${c.placeName ?? ""}</td>

    <td>

        <button type="button"
                class="btn btn-warning btn-sm edit-btn"
                data-index="${index}">
            تعديل
        </button>

        <button type="button"
                class="btn btn-danger btn-sm delete-btn"
                data-index="${index}">
            حذف
        </button>

    </td>

</tr>
`);

});

generateHiddenInputs();
}

// =====================
// CLEAR MODAL
// =====================
function clearModal() {

$("#cTitle").val("");

$("#cTime").val("");

$("#cType")
.val(null)
.trigger("change");

$("#cPriority")
.val(null)
.trigger("change");

$("#cPlace")
.val(null)
.trigger("change");

$("#cBranches")
.val([])
.trigger("change");

$("#cAttendances")
.val([])
.trigger("change");

$("#cNotes").val("");
}

// =====================
// HIDDEN INPUTS
// =====================
function generateHiddenInputs() {

let html = "";

commitments.forEach((c, i) => {

html += `
<input type="hidden"
       name="Commitments[${i}].Id"
       value="${c.id ?? 0}" />

<input type="hidden"
       name="Commitments[${i}].Title"
       value="${c.title ?? ''}" />

<input type="hidden"
       name="Commitments[${i}].Time"
       value="${c.time ?? ''}" />

<input type="hidden"
       name="Commitments[${i}].CommitmentTypeId"
       value="${c.commitmentTypeId}" />

<input type="hidden"
       name="Commitments[${i}].PriorityId"
       value="${c.priorityId}" />

<input type="hidden"
       name="Commitments[${i}].PlaceId"
       value="${c.placeId}" />

<input type="hidden"
       name="Commitments[${i}].Notes"
       value="${c.notes ?? ''}" />
`;

(c.branchIds || []).forEach(b => {

html += `
<input type="hidden"
       name="Commitments[${i}].BranchIds"
       value="${b}" />
`;
});

(c.attendanceIds || []).forEach(a => {

html += `
<input type="hidden"
       name="Commitments[${i}].AttendanceIds"
       value="${a}" />
`;
});

});

$("#hiddenCommitments").html(html);
}
</script>
