<script>

    let commitments = [];
    let editIndex = -1;
    let modal;

    $(document).ready(function () {

        // =====================
        // INIT MODAL (IMPORTANT)
        // =====================
        modal = new bootstrap.Modal(
            document.getElementById("commitmentModal")
        );

        // =====================
        // LOAD EDIT DATA
        // =====================
        @if (Model.Commitments != null && Model.Commitments.Count > 0)
        {
                <text>
                        commitments = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Commitments));
                        renderTable();
                </text>
        }

        // =====================
        // OPEN MODAL
        // =====================
        $("#btnAddCommitment").click(function () {

            clearModal();
            editIndex = -1;

            modal.show();

        });

        // =====================
        // SAVE
        // =====================
        $("#btnSaveCommitment").click(function () {

            if (!$("#cTitle").val()) {
                toastr.error("من فضلك أدخل عنوان الالتزام");
                return;
            }

            const commitment = {
                title: $("#cTitle").val(),
                time: $("#cTime").val(),
                commitmentTypeId: $("#cType").val(),
                priorityId: $("#cPriority").val(),
                placeId: $("#cPlace").val(),
                branchIds: $("#cBranches").val() || [],
                attendanceIds: $("#cAttendances").val() || [],
                notes: $("#cNotes").val(),
                typeText: $("#cType option:selected").text(),
                placeText: $("#cPlace option:selected").text()
            };

            if (editIndex >= 0)
                commitments[editIndex] = commitment;
            else
                commitments.push(commitment);

            renderTable();
            modal.hide();
        });

        // =====================
        // DELETE
        // =====================
        $(document).on("click", ".delete-btn", function () {

            let index = $(this).data("index");
            commitments.splice(index, 1);
            renderTable();
        });

        // =====================
        // EDIT
        // =====================
        $(document).on("click", ".edit-btn", function () {

            editIndex = $(this).data("index");

            let c = commitments[editIndex];

            $("#cTitle").val(c.title);
            $("#cTime").val(c.time);
            $("#cType").val(c.commitmentTypeId).trigger("change");
            $("#cPriority").val(c.priorityId).trigger("change");
            $("#cPlace").val(c.placeId).trigger("change");
            $("#cBranches").val(c.branchIds).trigger("change");
            $("#cAttendances").val(c.attendanceIds).trigger("change");
            $("#cNotes").val(c.notes);

            modal.show();
        });

        // =====================
        // SUBMIT
        // =====================
        $("#dailyPlanForm").submit(function () {
            generateHiddenInputs();
        });

    });


    // =====================
    // RENDER TABLE
    // =====================
    function renderTable() {

        let tbody = $("#commitmentsTableBody");
        tbody.empty();

        if (commitments.length === 0) {
            tbody.append(`
                <tr>
                    <td colspan="5" class="text-center text-muted">
                        لا توجد التزامات
                    </td>
                </tr>
            `);
            generateHiddenInputs();
            return;
        }

        commitments.forEach((c, index) => {

            tbody.append(`
                <tr>
                    <td>${c.time ?? ''}</td>
                    <td>${c.title}</td>
                    <td>${c.typeText ?? ''}</td>
                    <td>${c.placeText ?? ''}</td>
                    <td>
                        <button type="button" class="btn btn-warning btn-sm edit-btn" data-index="${index}">
                            تعديل
                        </button>

                        <button type="button" class="btn btn-danger btn-sm delete-btn" data-index="${index}">
                            حذف
                        </button>
                    </td>
                </tr>
            `);

        });

        generateHiddenInputs();
    }


    // =====================
    // CLEAR MODAL
    // =====================
    function clearModal() {

        $("#cTitle").val('');
        $("#cTime").val('');
        $("#cType").val(null).trigger("change");
        $("#cPriority").val(null).trigger("change");
        $("#cPlace").val(null).trigger("change");
        $("#cBranches").val([]).trigger("change");
        $("#cAttendances").val([]).trigger("change");
        $("#cNotes").val('');
    }


    // =====================
    // HIDDEN INPUTS
    // =====================
    function generateHiddenInputs() {

        let html = "";

        commitments.forEach((c, i) => {

            html += `
                <input type="hidden" name="Commitments[${i}].Title" value="${c.title}" />
                <input type="hidden" name="Commitments[${i}].Time" value="${c.time ?? ''}" />
                <input type="hidden" name="Commitments[${i}].CommitmentTypeId" value="${c.commitmentTypeId}" />
                <input type="hidden" name="Commitments[${i}].PriorityId" value="${c.priorityId}" />
                <input type="hidden" name="Commitments[${i}].PlaceId" value="${c.placeId}" />
                <input type="hidden" name="Commitments[${i}].Notes" value="${c.notes ?? ''}" />
            `;

            (c.branchIds || []).forEach(b => {
                html += `<input type="hidden" name="Commitments[${i}].BranchIds" value="${b}" />`;
            });

            (c.attendanceIds || []).forEach(a => {
                html += `<input type="hidden" name="Commitments[${i}].AttendanceIds" value="${a}" />`;
            });

        });

        $("#hiddenCommitments").html(html);
    }




        function openModal() {

        clearModal();
        editIndex = -1;

        modal.show();

        setTimeout(function () {

            $("#cType").select2({ dropdownParent: $("#commitmentModal") });
            $("#cPriority").select2({ dropdownParent: $("#commitmentModal") });
            $("#cPlace").select2({ dropdownParent: $("#commitmentModal") });
            $("#cBranches").select2({ dropdownParent: $("#commitmentModal") });
            $("#cAttendances").select2({ dropdownParent: $("#commitmentModal") });

        }, 200);
    }

    $("#btnAddCommitment").click(openModal);

</script>